{
  "name": "@loosilo/contextgraph-cli",
  "version": "0.1.0",
  "description": "CLI to manage ContextGraph MCP servers — index, search, memory, and blast radius for AI coding agents",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "cograph": "./src/index.ts"
  },
  "files": ["src"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/loosilo/contextgraph.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/loosilo/contextgraph#readme",
  "bugs": {
    "url": "https://github.com/loosilo/contextgraph/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "cli",
    "code-search",
    "semantic-search",
    "ai-agents",
    "claude",
    "cursor",
    "codebase-indexing"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --target bun --compile --outfile ./dist/cograph",
    "dev": "bun ./src/index.ts"
  },
  "dependencies": {
    "@loosilo/contextgraph-core": "0.1.0",
    "@loosilo/contextgraph-mcp": "0.1.0",
    "@loosilo/blastradius-mcp": "0.1.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5"
  }
}
